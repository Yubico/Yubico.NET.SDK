<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Yubico.YubiKit.Management.Examples.ManagementTool</RootNamespace>
    <AssemblyName>ManagementTool</AssemblyName>
    <IsPackable>false</IsPackable>
    
    <!-- Suppress analyzer warnings that are noisy for example/CLI apps -->
    <NoWarn>$(NoWarn);CA1852</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Spectre.Console" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Yubico.YubiKit.Management.csproj" />
    <ProjectReference Include="..\..\..\Yubico.YubiKit.Core\src\Yubico.YubiKit.Core.csproj" />
    <ProjectReference Include="..\..\..\Yubico.YubiKit.Cli.Shared\src\Yubico.YubiKit.Cli.Shared.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Spectre.Console">
      <HintPath>..\..\..\..\..\..\.nuget\packages\spectre.console\0.49.1\lib\net8.0\Spectre.Console.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
