# Shared config for the architecture-docs render/verify tooling.
# Sourced by render-architecture.sh and check-architecture-images.sh.
#
# Pinned Mermaid CLI version for reproducible renders (ISC-10). CI installs this
# exact version; local renders should match. Bump deliberately, then re-render.
MERMAID_CLI_VERSION="11.16.0"

# Ordered list of diagram image base-names, in the SAME order the ```mermaid
# fenced blocks appear in docs/architecture/sdk-architecture-diagrams.md.
# Index i (0-based) maps block i -> ARCH_IMAGE_NAMES[i].
#
# Current order (verified): L0, L1, L2, L3(apdu), L3b(fido), L4(discovery), L4(connection).
ARCH_IMAGE_NAMES=(
  "L0-context"
  "L1-assembly-deps"
  "L2-layered-stack"
  "L3-apdu-sequence"
  "L3b-fido2-ctap-sequence"
  "L4-discovery"
  "L4-connection"
)

ARCH_DIAGRAMS_FILE="docs/architecture/sdk-architecture-diagrams.md"
ARCH_IMAGES_DIR="docs/architecture/images"
ARCH_PNG_DIR="docs/architecture/images/png"
ARCH_MANIFEST="docs/architecture/images/image-manifest.txt"
ARCH_MERMAID_CONFIG="scripts/architecture/mermaid.config.json"
